# Terraform state — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local variable values — contains secrets, never commit
terraform.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
