# Copy this file to terraform.tfvars and fill in your values.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# terraform.tfvars is gitignored — NEVER commit it.

# ── AWS ────────────────────────────────────────────────────────────────────────
aws_region = "eu-central-1"
app_name   = "roulette"

# ── SSH ────────────────────────────────────────────────────────────────────────
# Paste the full contents of your public key file, e.g.:
#   cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... your-comment"

# ── Domain ─────────────────────────────────────────────────────────────────────
# The bare domain — Nginx will serve both @ and www
domain_name = "your-domain.com"

# ── Secrets ────────────────────────────────────────────────────────────────────
# Use strong random values. Avoid single-quote (') in db_password.
# Generate session_secret: openssl rand -hex 32
admin_password = "change-me-strong-admin-password"
session_secret = "change-me-at-least-32-characters-long-random-string"
db_password    = "change-me-strong-db-password"
